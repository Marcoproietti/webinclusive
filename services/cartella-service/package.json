{
  "name": "@webinclusive/cartella-service",
  "version": "1.0.0",
  "description": "WEB.INCLUSIVE — Cartella Socio-Sanitaria Elettronica (CSE)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev":         "tsx watch src/index.ts",
    "build":       "tsc --project tsconfig.json",
    "start":       "node dist/index.js",
    "test":        "vitest run",
    "typecheck":   "tsc --noEmit",
    "db:migrate":  "prisma migrate deploy",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@fastify/cors":       "^9.0.1",
    "@fastify/helmet":     "^11.1.1",
    "@fastify/jwt":        "^8.0.1",
    "@fastify/multipart":  "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@prisma/client":      "^5.14.0",
    "fastify":             "^4.28.1",
    "ioredis":             "^5.3.2",
    "minio":               "^8.0.0",
    "zod":                 "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "prisma":      "^5.14.0",
    "tsx":         "^4.16.2",
    "typescript":  "^5.5.3",
    "vitest":      "^1.6.0"
  }
}
