# ─────────────────────────────────────────────────────────
# services/auth-service/.env.example
# Copia in .env e compila con valori reali
# ─────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3001

# PostgreSQL
DATABASE_URL=postgresql://auth_user:password@localhost:5432/webinclusive?schema=auth

# Redis
REDIS_URL=redis://:your_redis_password@localhost:6379

# JWT (genera con: openssl rand -hex 64)
JWT_ACCESS_SECRET=your-64-byte-hex-secret-here

# Cookie firmato (genera con: openssl rand -hex 32)
COOKIE_SECRET=your-32-byte-hex-secret-here

# Refresh token TTL in giorni
REFRESH_TOKEN_TTL_DAYS=7

# Cifratura campi sensibili AES-256 (genera con: openssl rand -hex 32)
ENCRYPTION_KEY=your-32-byte-hex-key-here

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Security
BCRYPT_ROUNDS=12

# MFA
MFA_ISSUER=WEB.INCLUSIVE
