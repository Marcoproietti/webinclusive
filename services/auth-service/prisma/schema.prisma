// ─────────────────────────────────────────────────────────
// WEB.INCLUSIVE — Prisma Schema (auth-service)
// ─────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enum ──────────────────────────────────────────────────

enum UserRole {
  admin
  coordinator
  operator
  caregiver
  auditor
}

enum QualificationType {
  OSS
  OTS
  infermiere
  fisioterapista
  assistente_sociale
}

enum ContractType {
  tempo_indeterminato
  tempo_determinato
  partita_iva
  collaborazione
}

// ── User ─────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash")
  role         UserRole
  isActive     Boolean   @default(true) @map("is_active")
  mfaSecret    String?   @map("mfa_secret")
  mfaEnabled   Boolean   @default(false) @map("mfa_enabled")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Password history (ultimi 5 hash)
  passwordHistory PasswordHistory[]

  // Profili specifici per ruolo
  operator    Operator?
  caregiver   Caregiver?

  // Refresh tokens attivi
  refreshTokens RefreshToken[]

  // Audit log accessi
  auditLogs AuditLog[]

  @@map("users")
  @@schema("auth")
}

// ── Password History ──────────────────────────────────────

model PasswordHistory {
  id           Int      @id @default(autoincrement())
  userId       String   @map("user_id") @db.Uuid
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_history")
  @@schema("auth")
}

// ── Refresh Token ─────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash") // SHA-256 del token opaco
  deviceId  String?  @map("device_id")          // identificatore dispositivo mobile
  userAgent String?  @map("user_agent")
  ipAddress String?  @map("ip_address")
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
  @@schema("auth")
}

// ── Operator ─────────────────────────────────────────────

model Operator {
  id            String            @id @default(uuid()) @db.Uuid
  userId        String            @unique @map("user_id") @db.Uuid
  badgeNumber   String            @unique @map("badge_number") @db.VarChar(20)
  firstName     String            @map("first_name") // cifrato a livello app
  lastName      String            @map("last_name")  // cifrato
  fiscalCode    String            @unique @map("fiscal_code") @db.VarChar(16)
  qualification QualificationType
  contractType  ContractType      @map("contract_type")
  hireDate      DateTime          @map("hire_date") @db.Date
  territoryZone String?           @map("territory_zone") @db.VarChar(50)
  isAvailable   Boolean           @default(true) @map("is_available")
  deviceToken   String?           @map("device_token") // FCM/APNS token push
  deviceSecret  String?           @map("device_secret") // HMAC secret per proof-of-presence
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("operators")
  @@schema("auth")
}

// ── Caregiver ─────────────────────────────────────────────

model Caregiver {
  id              String  @id @default(uuid()) @db.Uuid
  userId          String  @unique @map("user_id") @db.Uuid
  beneficiaryId   String  @map("beneficiary_id") @db.Uuid
  firstName       String  @map("first_name") // cifrato
  lastName        String  @map("last_name")  // cifrato
  phone           String  // cifrato
  relationship    String  @db.VarChar(50)
  notificationPrefs Json  @default("{}") @map("notification_prefs")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("caregivers")
  @@schema("auth")
}

// ── Audit Log (append-only) ───────────────────────────────

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.Uuid
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  payload    Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("audit_logs")
  @@schema("auth")
}
