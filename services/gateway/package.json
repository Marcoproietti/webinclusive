{
  "name": "@webinclusive/gateway",
  "version": "1.0.0",
  "description": "WEB.INCLUSIVE — API Gateway (routing, auth, WS, rate limit)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev":       "tsx watch src/index.ts",
    "build":     "tsc --project tsconfig.json",
    "start":     "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors":       "^9.0.1",
    "@fastify/helmet":     "^11.1.1",
    "@fastify/http-proxy": "^9.4.0",
    "@fastify/jwt":        "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/websocket":  "^8.3.1",
    "@fastify/cookie":     "^9.3.1",
    "fastify":             "^4.28.1",
    "ioredis":             "^5.3.2",
    "zod":                 "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "tsx":         "^4.16.2",
    "typescript":  "^5.5.3"
  }
}
