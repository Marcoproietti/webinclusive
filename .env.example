# ─────────────────────────────────────────────────────────
# WEB.INCLUSIVE — .env.example (produzione)
# Copia in .env e compila tutti i valori
# MAI committare il file .env reale in git
# ─────────────────────────────────────────────────────────

# ── Database principale ───────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres:5432/webinclusive

# ── Database Whistleblowing (SEPARATO) ───────────────────
WB_POSTGRES_USER=wb_admin
WB_POSTGRES_PASSWORD=CHANGE_ME_DIFFERENT_PASSWORD
WB_DATABASE_URL=postgresql://wb_admin:CHANGE_ME@postgres-wb:5433/wb_db

# ── Redis ─────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── JWT & Cookie (genera con: openssl rand -hex 64) ───────
JWT_ACCESS_SECRET=GENERATE_WITH_openssl_rand_-hex_64
COOKIE_SECRET=GENERATE_WITH_openssl_rand_-hex_32

# ── Cifratura AES-256 (genera con: openssl rand -hex 32) ──
ENCRYPTION_KEY=GENERATE_WITH_openssl_rand_-hex_32
# Chiave SEPARATA per whistleblowing
WB_ENCRYPTION_KEY=GENERATE_WITH_openssl_rand_-hex_32_DIFFERENT
WB_REPORTER_HMAC_KEY=GENERATE_WITH_openssl_rand_-hex_32_DIFFERENT

# ── MinIO ─────────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET

# ── CORS ──────────────────────────────────────────────────
ALLOWED_ORIGINS=https://app.webinclusive.it

# ── Firebase FCM (Android push) ───────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# ── SMTP ──────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@webinclusive.it
SMTP_PASS=your-smtp-app-password
SMTP_FROM=noreply@webinclusive.it

# ── Rate limiting ─────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10

# ── Geofence & Sync ───────────────────────────────────────
GEOFENCE_RADIUS_METERS=200
OFFLINE_SYNC_MAX_HOURS=2

# ── Security ──────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Monitoring ────────────────────────────────────────────
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
